###Pure
Class <<temporal.businesstemporal>> {doc.description = 'A person'} model::domain::Person extends model::domain::LegalEntity
[
    $this.name->isNotEmpty(),
    ageConstraint: $this.age >= 0
]
{
    name: String[1];
    age: Integer[0..1];
    fullName(sep: String[1])
    {
        $this.firstName + $sep + $this.lastName
    }: String[1];
}
